{
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "LoadBearing",
          "version": "0.1.0",
          "informationUri": "https://github.com/andypgray/loadbearing",
          "rules": [
            {
              "id": "layering/domain-independent",
              "shortDescription": {
                "text": "The Domain layer must not reference the Web layer."
              },
              "fullDescription": {
                "text": "Domain is UI-agnostic; transaction boundaries live in services."
              },
              "help": {
                "text": "Define an abstraction in Domain and implement it in Web."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "enforce"
              }
            },
            {
              "id": "layering/billing-independent",
              "shortDescription": {
                "text": "Types in `MyApp.Legacy.Billing.*` must not reference types in `MyApp.Web.*`."
              },
              "fullDescription": {
                "text": "Billing must not reach up into the web layer."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "enforce"
              }
            },
            {
              "id": "data-access/no-inline-sql",
              "shortDescription": {
                "text": "Types in the Web layer named `*Controller` must not reference types in `System.Data.*`."
              },
              "fullDescription": {
                "text": "Repository pattern for testability."
              },
              "help": {
                "text": "Inject the repository."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "migrate"
              }
            },
            {
              "id": "time/inject-clock",
              "shortDescription": {
                "text": "The Web layer must not use `DateTime.Now` or `DateTime.UtcNow`."
              },
              "fullDescription": {
                "text": "Wall-clock reads are untestable; inject IClock."
              },
              "help": {
                "text": "Take IClock in the constructor; see OrderService for the pattern."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "migrate"
              }
            },
            {
              "id": "naming/async-suffix",
              "shortDescription": {
                "text": "Methods of the Web layer returning `Task` or `Task<TResult>` must be named `*Async`."
              },
              "fullDescription": {
                "text": "Async methods are discovered by their Async suffix."
              },
              "help": {
                "text": "Rename the method to end in Async and update its callers."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "migrate"
              }
            },
            {
              "id": "di/handlers-via-registry",
              "shortDescription": {
                "text": "Types, except `HandlerRegistry` must not construct types implementing `IHandler<T>`."
              },
              "fullDescription": {
                "text": "Handlers are resolved through HandlerRegistry; direct construction bypasses discovery."
              },
              "help": {
                "text": "Resolve the handler through HandlerRegistry instead of constructing it."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "migrate"
              }
            },
            {
              "id": "di/no-captive-dependencies",
              "shortDescription": {
                "text": "Singleton-registered types must not inject scoped-registered types or transient-registered types."
              },
              "fullDescription": {
                "text": "A singleton that captures a scoped or transient service pins it to the whole process lifetime."
              },
              "help": {
                "text": "Inject IServiceScopeFactory and resolve the dependency inside a scope."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "migrate"
              }
            },
            {
              "id": "layering/no-ghost",
              "shortDescription": {
                "text": "Types in `MyApp.Domain.*` must not reference types in `MyApp.Ghost.*`."
              },
              "fullDescription": {
                "text": "Nothing should reference the (nonexistent) ghost layer."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "enforce"
              }
            },
            {
              "id": "naming/nonexistent",
              "shortDescription": {
                "text": "Types in `MyApp.Nowhere.*` must be named `*Service`."
              },
              "fullDescription": {
                "text": "A subject that matches nothing must fail loudly."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "enforce"
              }
            },
            {
              "id": "legacy/billing/containment",
              "shortDescription": {
                "text": "Types in `MyApp.Legacy.Billing.*`, except `IBillingFacade` or `BillingFacade` must be referenced only by types in `MyApp.Legacy.Billing.*`, `IBillingFacade` or `BillingFacade`."
              },
              "fullDescription": {
                "text": "Replacement scheduled; not worth stabilizing."
              },
              "help": {
                "text": "use `IBillingFacade`"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "freeze"
              }
            },
            {
              "id": "legacy/billing/tripwire",
              "fullDescription": {
                "text": "Replacement scheduled; not worth stabilizing."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "posture": "freeze"
              }
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
